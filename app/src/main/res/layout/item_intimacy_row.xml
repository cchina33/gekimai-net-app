<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/tvCharName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="@string/label_name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvCurrentLevel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:text="@string/placeholder_zero"
            android:textSize="13sp"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvGoalLevel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:text="@string/placeholder_zero"
            android:textSize="13sp"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvRequiredItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="@string/placeholder_dash"
            android:textSize="12sp"
            android:textAlignment="viewEnd"
            android:textColor="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tvTotalCost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="@string/placeholder_zero"
            android:textSize="12sp"
            android:textAlignment="viewEnd"
            android:textStyle="bold"
            android:textColor="?attr/colorTertiary" />
    </LinearLayout>

    <!-- 旧レイアウトの互換性のための非表示要素 -->
    <TextView android:id="@+id/tvLevel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/tvNext" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/tvReward" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="?attr/colorOutlineVariant" />
</LinearLayout>
